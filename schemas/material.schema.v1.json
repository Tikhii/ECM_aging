{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "material.schema.v1.json",
  "title": "Material Spec Schema v1",
  "description": "Cell type material specification schema. Captures intrinsic physical properties of a battery cell that are independent of the degradation mechanism model.",
  "type": "object",
  "definitions": {
    "value_with_provenance": {
      "type": "object",
      "properties": {
        "value": {
          "type": ["number", "null"],
          "description": "The parameter value. null means pending_fit (not yet determined)."
        },
        "status": {
          "type": "string",
          "enum": ["pending_fit", "fitted", "manually_set", "literature_default", "convention", "datasheet"],
          "description": "Provenance status of this parameter value."
        },
        "fit_step": {
          "type": ["string", "null"],
          "description": "Which FIT step produced this value (e.g. 'FIT-1'). null if not fitted."
        },
        "fit_source": {
          "type": ["string", "null"],
          "description": "Source script or notebook that produced the fit. null if not fitted."
        },
        "fit_script_version": {
          "type": ["string", "null"],
          "description": "Git commit or version tag of the fit script. null if not fitted."
        },
        "fit_r_squared": {
          "type": ["number", "null"],
          "description": "R-squared goodness-of-fit metric. null if not fitted."
        },
        "uncertainty": {
          "type": ["number", "null"],
          "description": "Uncertainty estimate for the value. null if unknown."
        },
        "last_modified_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of last modification."
        }
      },
      "required": ["value", "status", "fit_step", "fit_source", "fit_script_version", "fit_r_squared", "uncertainty", "last_modified_at"],
      "additionalProperties": true,
      "if": {
        "properties": { "status": { "const": "fitted" } }
      },
      "then": {
        "properties": {
          "fit_step": { "type": "string" },
          "fit_source": { "type": "string" },
          "fit_script_version": { "type": "string" },
          "fit_r_squared": { "type": "number" }
        }
      },
      "else": {
        "properties": {
          "fit_step": { "const": null },
          "fit_source": { "const": null },
          "fit_script_version": { "const": null },
          "fit_r_squared": { "const": null }
        }
      }
    }
  },
  "properties": {
    "schema_version": {
      "const": "material.v1",
      "description": "Schema version identifier."
    },
    "cell_type": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Cell type identifier in snake_case (e.g. 'panasonic_ncr18650b')."
    },
    "chemistry": {
      "type": "string",
      "description": "Cell chemistry description (e.g. 'NCA/Graphite')."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of spec creation."
    },
    "last_modified_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last modification."
    },
    "C_nominal_Ah": {
      "$ref": "#/definitions/value_with_provenance",
      "description": "Nominal capacity [Ah]. Intrinsic property from datasheet.",
      "x-nature": "intrinsic"
    },
    "V_max": {
      "$ref": "#/definitions/value_with_provenance",
      "description": "Maximum operating voltage [V]. Intrinsic property from datasheet.",
      "x-nature": "intrinsic"
    },
    "V_min": {
      "$ref": "#/definitions/value_with_provenance",
      "description": "Minimum operating voltage [V]. Intrinsic property from datasheet.",
      "x-nature": "intrinsic"
    },
    "X0_PE": {
      "$ref": "#/definitions/value_with_provenance",
      "description": "Initial positive electrode stoichiometry at full charge. Intrinsic property.",
      "x-nature": "intrinsic"
    },
    "X0_NE": {
      "$ref": "#/definitions/value_with_provenance",
      "description": "Initial negative electrode stoichiometry at full charge. Intrinsic property.",
      "x-nature": "intrinsic"
    },
    "dX_PE_alawa": {
      "$ref": "#/definitions/value_with_provenance",
      "description": "Positive electrode cyclable stoichiometry span (from alawa data). Intrinsic property.",
      "x-nature": "intrinsic"
    },
    "dX_NE_alawa": {
      "$ref": "#/definitions/value_with_provenance",
      "description": "Negative electrode cyclable stoichiometry span (from alawa data). Intrinsic property.",
      "x-nature": "intrinsic"
    },
    "LR": {
      "$ref": "#/definitions/value_with_provenance",
      "description": "Loading ratio C_NE/C_PE. Intrinsic property, determined by FIT-1.",
      "x-nature": "intrinsic"
    },
    "OFS": {
      "$ref": "#/definitions/value_with_provenance",
      "description": "Offset as percentage of PE capacity, representing formation SEI. Intrinsic property, determined by FIT-1.",
      "x-nature": "intrinsic"
    },
    "anode_thermo_dat": {
      "type": "string",
      "description": "Relative path (from project root) to the anode half-cell thermodynamic data file (.dat format)."
    },
    "cathode_thermo_dat": {
      "type": "string",
      "description": "Relative path (from project root) to the cathode half-cell thermodynamic data file (.dat format)."
    },
    "mvol_ne_mode": {
      "type": "string",
      "enum": ["graphite_standard", "custom"],
      "description": "Molar volume model selector for the negative electrode."
    },
    "mvol_ne_coeff": {
      "type": ["array", "null"],
      "items": { "type": "number" },
      "minItems": 10,
      "maxItems": 10,
      "description": "Custom molar volume polynomial coefficients for NE (10 coefficients, high-to-low order). null when using a standard mode."
    },
    "mvol_pe_mode": {
      "type": "string",
      "enum": ["nca_standard", "lfp_linear", "custom"],
      "description": "Molar volume model selector for the positive electrode."
    },
    "mvol_pe_coeff": {
      "type": ["array", "null"],
      "items": { "type": "number" },
      "minItems": 10,
      "maxItems": 10,
      "description": "Custom molar volume polynomial coefficients for PE (10 coefficients, high-to-low order). null when using a standard mode."
    }
  },
  "required": [
    "schema_version", "cell_type", "chemistry", "created_at", "last_modified_at",
    "C_nominal_Ah", "V_max", "V_min", "X0_PE", "X0_NE",
    "dX_PE_alawa", "dX_NE_alawa", "LR", "OFS",
    "anode_thermo_dat", "cathode_thermo_dat",
    "mvol_ne_mode", "mvol_ne_coeff", "mvol_pe_mode", "mvol_pe_coeff"
  ],
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": { "mvol_ne_mode": { "const": "graphite_standard" } }
      },
      "then": {
        "properties": { "mvol_ne_coeff": { "const": null } }
      }
    },
    {
      "if": {
        "properties": { "mvol_ne_mode": { "const": "custom" } }
      },
      "then": {
        "properties": {
          "mvol_ne_coeff": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 10,
            "maxItems": 10
          }
        }
      }
    },
    {
      "if": {
        "properties": { "mvol_pe_mode": { "const": "nca_standard" } }
      },
      "then": {
        "properties": { "mvol_pe_coeff": { "const": null } }
      }
    },
    {
      "if": {
        "properties": { "mvol_pe_mode": { "const": "lfp_linear" } }
      },
      "then": {
        "properties": { "mvol_pe_coeff": { "const": null } }
      }
    },
    {
      "if": {
        "properties": { "mvol_pe_mode": { "const": "custom" } }
      },
      "then": {
        "properties": {
          "mvol_pe_coeff": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 10,
            "maxItems": 10
          }
        }
      }
    }
  ]
}
